<#
{
    "Category": 2,
    "Name": "Admin Counsel Queue",
    "Info": "Auto-clears the counsel queue, removing entries from the past month. [Pharmacist credentials required] [Start on Home screen]",
    "Shortcut": "Shift + F2",
    "Code": "1137",
    "Window": "Minimized",
    "Programs": "java.exe"
}
#>

$dllvar = '[DllImport("user32.dll")] public static extern bool ShowWindow(int handle, int state);'
add-type -name win -member $dllvar -namespace native
[native.win]::ShowWindow(([System.Diagnostics.Process]::GetCurrentProcess() | Get-Process).MainWindowHandle, 0)

# Set the working directory to the script's location
$scriptDir = Split-Path -Path $MyInvocation.MyCommand.Definition -Parent
Set-Location -Path $scriptDir

# Load variables from precheck.ps1
. .\precheck.ps1

# Check the exit code of the last command
if ($LASTEXITCODE -ne 0) {
    . .\errorHandler.ps1 $global:precheckError
    exit 1
}

# List of variables to check
$variables = @{
    "Main" = $Main
    "Clavier" = $Clavier
    "Cap2Txt" = $Cap2Txt
    "SendKeys" = $SendKeys
    "Printer" = $Printer
}

# Check if all necessary variables are defined
foreach ($var in $variables.GetEnumerator()) {
    if (-not $var.Value) {
        $errorMessage = "Error: '$($var.Key)' is not defined.`nOpen Setup [Shift + F1]"
        . ./errorHandler.ps1 $errorMessage
        exit 1
    }
}

# 1) Safe, disposable pixel reader with optional neighborhood averaging
function Get-ScreenColor {
    [CmdletBinding(DefaultParameterSetName='Cursor')]
    param(
        [Parameter(Mandatory=$true, ParameterSetName='Point')][int]$X,
        [Parameter(Mandatory=$true, ParameterSetName='Point')][int]$Y,
        [int]$Kernel = 0,   # 0=single pixel; 1=3x3, 2=5x5 (averaged)
        [switch]$Raw       # return [System.Drawing.Color] when set
    )

    if ($PSCmdlet.ParameterSetName -eq 'Cursor') {
        $p = [System.Windows.Forms.Cursor]::Position
        $X = $p.X; $Y = $p.Y
    }

    $w = $h = (2 * $Kernel + 1)
    $bmp = New-Object System.Drawing.Bitmap($w, $h)
    try {
        $g = [System.Drawing.Graphics]::FromImage($bmp)
        try {
            $g.CopyFromScreen(
                [System.Drawing.Point]::new($X - $Kernel, $Y - $Kernel),
                [System.Drawing.Point]::Empty,
                [System.Drawing.Size]::new($w, $h)
            )
        } finally { $g.Dispose() }

        if ($Kernel -le 0) {
            $c = $bmp.GetPixel([Math]::Min($Kernel,$w-1), [Math]::Min($Kernel,$h-1))
        } else {
            $sumR = $sumG = $sumB = 0
            for ($yy=0; $yy -lt $h; $yy++) {
                for ($xx=0; $xx -lt $w; $xx++) {
                    $p = $bmp.GetPixel($xx,$yy)
                    $sumR += $p.R; $sumG += $p.G; $sumB += $p.B
                }
            }
            $px = $w * $h
            $r = [int][Math]::Round($sumR / $px)
            $gC= [int][Math]::Round($sumG / $px)
            $b = [int][Math]::Round($sumB / $px)
            $c = [System.Drawing.Color]::FromArgb($r,$gC,$b)
        }

        if ($Raw) { return $c }
        else { return ("rgb({0}, {1}, {2})" -f $c.R, $c.G, $c.B) }
    }
    finally { $bmp.Dispose() }
}

# 2) Wait until the cursor stops moving (so we don't sample mid-flight)
function Wait-CursorStable {
    param(
        [int]$StableMs = 100,
        [int]$PollMs   = 20,
        [int]$TimeoutMs= 2000
    )
    $deadline = (Get-Date).AddMilliseconds($TimeoutMs)
    $stableFor = 0
    $last = [System.Windows.Forms.Cursor]::Position
    while ((Get-Date) -lt $deadline) {
        Start-Sleep -Milliseconds $PollMs
        $now = [System.Windows.Forms.Cursor]::Position
        if ($now.X -eq $last.X -and $now.Y -eq $last.Y) {
            $stableFor += $PollMs
            if ($stableFor -ge $StableMs) { return $now }
        } else {
            $last = $now; $stableFor = 0
        }
    }
    return $null
}

# 3) Color math + majority classification with tolerance ("near green" support)
function Get-ColorDistance([System.Drawing.Color]$a, [System.Drawing.Color]$b) {
    $dr = $a.R - $b.R; $dg = $a.G - $b.G; $db = $a.B - $b.B
    [Math]::Sqrt($dr*$dr + $dg*$dg + $db*$db)
}

function Test-ColorBucket {
    param(
        [System.Drawing.Color[]]$Samples,
        [hashtable]$Targets,   # e.g. @{ MTMGreen = [Drawing.Color]::FromArgb(0,178,0) }
        [hashtable]$Skips,     # e.g. @{ Black = [Drawing.Color]::FromArgb(0,0,0) }
        [int]$Tolerance = 18
    )
    $hit = @{}; foreach($k in $Targets.Keys){ $hit[$k]=0 }
    $miss= @{}; foreach($k in $Skips.Keys){   $miss[$k]=0 }

    foreach($s in $Samples){
        foreach($k in $Targets.Keys){ if((Get-ColorDistance $s $Targets[$k]) -le $Tolerance){ $hit[$k]++ } }
        foreach($k in $Skips.Keys){   if((Get-ColorDistance $s $Skips[$k])   -le $Tolerance){ $miss[$k]++ } }
    }
    $n = [Math]::Max(1,$Samples.Count)
    $bestHitName=$null; $bestHit=-1
    foreach($k in $hit.Keys){ if($hit[$k] -gt $bestHit){ $bestHit=$hit[$k]; $bestHitName=$k } }
    $bestMissName=$null; $bestMiss=-1
    foreach($k in $miss.Keys){ if($miss[$k]-gt $bestMiss){$bestMiss=$miss[$k];$bestMissName=$k} }

    if ($bestHit  -ge [Math]::Ceiling($n/2.0)) { return @{ Result='Success'; Name=$bestHitName;  Count=$bestHit } }
    if ($bestMiss -ge [Math]::Ceiling($n/2.0)) { return @{ Result='Skip';    Name=$bestMissName; Count=$bestMiss } }
    return @{ Result='Unknown'; Name=$null; Count=0 }
}

# 4) Debounced wait for a pixel to classify as Success/Skip with multi-sampling
function Wait-Pixel {
    param(
        [int]$X, [int]$Y,
        [hashtable]$Targets,
        [hashtable]$Skips,
        [int]$Tolerance      = 70,
        [int]$StableReads    = 2,
        [int]$SamplesPerRead = 2,
        [int]$Kernel         = 1,
        [int]$InterSampleMs  = 10,
        [int]$SettleMs       = 10,
        [int]$TimeoutMs      = 300
    )
    $deadline = (Get-Date).AddMilliseconds($TimeoutMs)
    $stable = 0
    while ((Get-Date) -lt $deadline) {
        Start-Sleep -Milliseconds $SettleMs
        $samples = @()
        for ($i=0; $i -lt $SamplesPerRead; $i++) {
            $samples += (Get-ScreenColor -X $X -Y $Y -Raw -Kernel $Kernel)
            if ($i -lt $SamplesPerRead-1) { Start-Sleep -Milliseconds $InterSampleMs }
        }
        $cls = Test-ColorBucket -Samples $samples -Targets $Targets -Skips $Skips -Tolerance $Tolerance
        switch ($cls.Result) {
            'Success' { $stable++; if ($stable -ge $StableReads) { return @{ Result='Success'; X=$X; Y=$Y; Bucket=$cls.Name } } }
            'Skip'    { return @{ Result='Skip';    X=$X; Y=$Y; Bucket=$cls.Name } }
            default   { $stable = 0 }
        }
    }
    return @{ Result='Timeout'; X=$X; Y=$Y }
}

Add-Type -AssemblyName PresentationFramework
Add-Type -AssemblyName System.Windows.Forms
Add-Type -AssemblyName System.Drawing
Add-type -AssemblyName microsoft.VisualBasic

# --------------------
# FORM (WPF/XAML) — uniform 10px spacing + hold-to-reveal password
# --------------------

# Font fallback like the sample
try {
    $fontName = "Segoe UI Variable"
    $font = New-Object System.Windows.Media.FontFamily($fontName)
    $null = $font.FamilyNames
} catch { $fontName = "Segoe UI" }

# XAML with 10px spacers between rows and a watermark glyph
$xaml = @"
<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Enterprise Pharmacy System"
        Height="188" Width="335"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5FA"
        FontFamily="$fontName"
        FontSize="14">
    <Grid Margin="0">
        <!-- Background watermark (you used a bold 'Q' label in WinForms) -->
        <TextBlock Text="Q"
                   FontSize="70"
                   FontWeight="Bold"
                   Opacity="1"
                   Foreground="#ededed"
                   VerticalAlignment="Bottom"
                   HorizontalAlignment="Left"
                   Margin="13,0,0,-1"
                   IsHitTestVisible="False"
                   Panel.ZIndex="0"/>

        <!-- Main content grid -->
        <Grid Margin="18,18,18,18" Panel.ZIndex="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Row 0: User -->
                <RowDefinition Height="10"/>   <!-- Row 1: spacer -->
                <RowDefinition Height="Auto"/> <!-- Row 2: Password -->
                <RowDefinition Height="10"/>   <!-- Row 3: spacer -->
                <RowDefinition Height="Auto"/> <!-- Row 4: Buttons -->
                <RowDefinition Height="10"/>   <!-- Row 5: spacer -->
                <RowDefinition Height="Auto"/> <!-- Row 6: Error -->
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="210"/>
            </Grid.ColumnDefinitions>

            <!-- User row -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="User" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="UserBox" Grid.Row="0" Grid.Column="1"
                     Width="210" Height="28" BorderThickness="2" Padding="1.5,3"/>

            <!-- Password row -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Password" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <Grid Grid.Row="2" Grid.Column="1">
                <Grid>
                    <PasswordBox x:Name="PassBox"
                                 Height="28"
                                 Padding="1.5,1.5,28,1.5"
                                 VerticalContentAlignment="Center"
                                 BorderThickness="2"
                                 Margin="0"/>
                    <TextBox x:Name="PassText"
                             Height="28"
                             Padding="1.5,1.5,28,1.5"
                             VerticalContentAlignment="Center"
                             BorderThickness="2"
                             Margin="0"
                             Visibility="Collapsed"/>
                    <Button x:Name="TogglePassBtn"
                            Content="👁"
                            Width="24"
                            Height="24"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,2,0"
                            Background="Transparent"
                            BorderBrush="{x:Null}"
                            BorderThickness="0"
                            ToolTip="Hold to reveal password"
                            IsTabStop="False"
                            Cursor="Hand"/>
                </Grid>
            </Grid>

            <!-- Buttons -->
            <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="OkBtn"
                        Content="Submit"
                        Width="102"
                        Height="36"
                        FontWeight="Bold"
                        IsEnabled="False"
                        IsDefault="True">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Background" Value="#569de5"/>
                            <Setter Property="BorderThickness" Value="2"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="3">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#4d8dce"/>
                                            </Trigger>
                                            <Trigger Property="IsFocused" Value="True">
                                                <Setter Property="Background" Value="#4d8dce"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="BorderBrush" Value="#aaa"/>
                                                <Setter Property="Background" Value="#ddd"/>
                                                <Setter Property="Foreground" Value="white"/>
                                                <Setter Property="Cursor" Value="Arrow"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="True">
                                                <Setter Property="BorderThickness" Value="0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button x:Name="CancelBtn"
                        Content="Cancel"
                        Width="102"
                        Height="36"
                        FontWeight="Bold"
                        BorderBrush="#888"
                        Margin="6,0,0,0"
                        HorizontalAlignment="Right">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#c84e38"/>
                            <Setter Property="Foreground" Value="white"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#C23B22"/>
                                            </Trigger>
                                            <Trigger Property="IsFocused" Value="True">
                                                <Setter Property="Background" Value="#C23B22"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- Error display (kept for parity; hidden by default) -->
            <TextBlock x:Name="ErrorBlock"
                       Grid.Row="6" Grid.ColumnSpan="2"
                       Foreground="Red"
                       Margin="0,0,0,0"
                       FontSize="12"
                       Visibility="Collapsed"/>
        </Grid>
    </Grid>
</Window>
"@

# Parse + create window
$reader    = New-Object System.IO.StringReader $xaml
$xmlreader = [System.Xml.XmlTextReader]::new($reader)
$window    = [Windows.Markup.XamlReader]::Load($xmlreader)

# Grab controls
$UserBox       = $window.FindName("UserBox")
$PassBox       = $window.FindName("PassBox")
$PassText      = $window.FindName("PassText")
$TogglePassBtn = $window.FindName("TogglePassBtn")
$OkBtn         = $window.FindName("OkBtn")
$CancelBtn     = $window.FindName("CancelBtn")
$ErrorBlock    = $window.FindName("ErrorBlock")
$TogglePassBtn.Focusable = $false

# Validation: enable Submit only when both user + password present
function Validate-Inputs {
    if ($UserBox.Text -and $PassBox.Password) {
        $OkBtn.IsEnabled = $true
        $ErrorBlock.Visibility = "Collapsed"
    } else {
        $OkBtn.IsEnabled = $false
    }
}
$UserBox.Add_TextChanged({ Validate-Inputs })
$PassBox.Add_PasswordChanged({ Validate-Inputs })

# Buttons
$CancelBtn.Add_Click({ $window.DialogResult = $false; $window.Close() })
$OkBtn.Add_Click({     $window.DialogResult = $true ; $window.Close() })

# Password reveal (press-and-hold)
$TogglePassBtn.Add_PreviewMouseLeftButtonDown({
    $PassText.Text       = $PassBox.Password
    $PassBox.Visibility  = "Collapsed"
    $PassText.Visibility = "Visible"
})
$TogglePassBtn.Add_PreviewMouseLeftButtonUp({
    $PassBox.Password    = $PassText.Text
    $PassBox.Visibility  = "Visible"
    $PassText.Visibility = "Collapsed"
})

# UX niceties
$UserBox.Add_GotFocus({ $UserBox.Dispatcher.InvokeAsync({ $UserBox.SelectAll() }, "Background") })
$PassBox.Add_GotFocus({ $PassBox.Dispatcher.InvokeAsync({ $PassBox.SelectAll() }, "Background") })
$PassText.Add_GotFocus({ $PassText.Dispatcher.InvokeAsync({ $PassText.SelectAll() }, "Background") })

$window.Topmost = $true
$window.Add_ContentRendered({
    $window.Activate()
    [Microsoft.VisualBasic.Interaction]::AppActivate("Enterprise Pharmacy System")
    $UserBox.Focus()
})

# Escape helper for Clavier special characters used in tokens: \ [ ] { }
function Escape-ClavierText {
    param([string]$Text)
    if ($null -eq $Text) { return "" }
    $Text = $Text -replace '\\', '\\\\'
    $Text = $Text -replace '\[',  '\\['
    $Text = $Text -replace '\]',  '\\]'
    $Text = $Text -replace '\{',  '\\{'
    $Text = $Text -replace '\}',  '\\}'
    return $Text
}

# Show modal and translate result to your existing $result6 pattern
$result = $window.ShowDialog()

# (Keep downstream logic unchanged by providing $result6 and simple user/pass objects with .Text)
if ($result -eq $true) {
    $result6 = [System.Windows.Forms.DialogResult]::OK
} else {
    $result6 = [System.Windows.Forms.DialogResult]::Cancel
}

# Build $Auth like before, but escape special characters
$UserEsc = Escape-ClavierText ( ($UserBox.Text).Trim() )
$PassEsc = Escape-ClavierText $PassBox.Password

# Provide $User and $Pass with a .Text property so your later code remains identical
$User = [pscustomobject]@{ Text = $UserBox.Text }
$Pass = [pscustomobject]@{ Text = $PassBox.Password }

# Same composed EPS login sequence your script expects
$Auth = "[{Focus,0,Enterprise Pharmacy System}]" + "[{MouseMoveToFocus,100,93}][][{MouseButton,L}]" + "[{MouseMoveToFocus,50,146}][][{MouseButton,L}]" + $UserEsc + "[TAB][]" + $PassEsc + "[ENTER]"

if ($result6 -eq [System.Windows.Forms.DialogResult]::OK) {

    #Move EPS to the side
    & $Clavier /sendkeys "[{Focus,0,*EPS/*}][{MouseMoveToFocus,0,0}][{MouseButton,LD}][{MouseMoveTo,880,250}][][{MouseButton,LU}]"
    Start-sleep -Milliseconds 100

    #Focus EPS and Launch Counseling Queue
    & $Clavier /sendkeys "[{Focus,0,*EPS/*}][][Ctrl+G]"
    Start-sleep -Milliseconds 800

    #Calculate -1 month from Today (original code uses -2; preserved as-is)
    $MonthAgo = (Get-Date).AddMonths(-2).ToString("MM-dd-yyyy")
    $StartWC = "[{Focus,0,*EPS/*}][{MouseMoveToFocus,40,190}][{MouseButton,L}][Ctrl+A][]" + $MonthAgo + "[Tab][][Alt+F]"

    #Target Start WC Date
    & $Clavier /sendkeys $StartWC
    Start-sleep -Milliseconds 800

    $Done = 0
    Do {
        #Check List
        $ListSuccess = 0
        $ListEmpty = 0
        $endTime = (Get-Date).Add((New-TimeSpan -Seconds 3))
        Do {
            & $Clavier /sendkeys "[{Focus,0,*EPS/*}][{MouseMoveToFocus,382,665}]"
            Start-sleep -Milliseconds 40

            # --- ROBUST COLOR CHECK (replaces string compare for records/empty) ---
            $anchor = Wait-CursorStable -StableMs 50 -PollMs 20 -TimeoutMs 1500
            if ($anchor) {
                $targets = @{ Records = [System.Drawing.Color]::FromArgb(206,225,242) }  # "records found" blue-ish
                $skips   = @{ Empty   = [System.Drawing.Color]::FromArgb(211,211,211) }  # empty list gray

                $cls = Wait-Pixel -X $anchor.X -Y $anchor.Y -Targets $targets -Skips $skips -Tolerance 70 -StableReads 2 -SamplesPerRead 2 -Kernel 1 -SettleMs 10 -TimeoutMs 1000

                if ($cls.Result -eq 'Success') {
                    write-host "RECORDS FOUND (bucket:$($cls.Bucket))"
                    $ListSuccess = 1
                }
                elseif ($cls.Result -eq 'Skip') {
                    $Done = 1
                    write-host "LIST EMPTY (bucket:$($cls.Bucket))"
                    exit     # preserve original behavior (exits immediately)
                    $ListEmpty = 1  # (will not be reached; preserved for parity)
                }
                # else Unknown/Timeout: let loop retry until endTime
            } else {
                # If anchor didn't stabilize, let the loop retry quickly
                Start-Sleep -Milliseconds 100
            }
            # --- END ROBUST COLOR CHECK ---

        } Until (($ListSuccess -eq 1) -or ($ListEmpty -eq 1) -or ((Get-Date) -gt $endTime))

        #Start Counsel Loop
        & $Clavier /sendkeys "[Alt+O]"
        Start-sleep -Milliseconds 300
        if (-not ([Microsoft.VisualBasic.Interaction]::AppActivate("Error"))) {
            Write-Host "EXIT: ERROR"
            exit
        }
        Start-sleep -Milliseconds 400

        #Check For Window "Multiple"
        $timeout1 = New-TimeSpan -Seconds 1
        $endTime1 = (Get-Date).Add($timeout1)
        $Multiple = 0
        Do {
            if (-not ([Microsoft.VisualBasic.Interaction]::AppActivate("Multiple"))) {
                #Click Yes
                & $Clavier /sendkeys "[{Focus,0,Multiple*}][Alt+Y]"
                Start-sleep -Milliseconds 400

                #Select All and Continue
                & $Clavier /sendkeys "[{Focus,0,Multiple*}][Alt+A][][Alt+S]"
                Start-sleep -Milliseconds 400
                $Multiple = 1
            }
        } Until ($Multiple -eq 1 -or ((Get-Date) -gt $endTime1))

        $MTMSuccess = 0
        $MTMSkip    = 0

        # Move once to the known relative point
        & $Clavier /sendkeys "[{Focus,0,*EPS/*}][{MouseMoveToFocus,701,692}]"
        Start-sleep -Milliseconds 40

        # Wait for pointer to stop moving and lock absolute X/Y
        $anchor = Wait-CursorStable -StableMs 50 -PollMs 25 -TimeoutMs 1000
        if (-not $anchor) {
            # If the pointer never stabilizes
            $MTMSkip = 1 
            exit
        } else {
            # Define the colors (with tolerance)

            $targets = @{ MTMGreen = [System.Drawing.Color]::FromArgb(0,178,0) }
            $skips   = @{
                Black = [System.Drawing.Color]::FromArgb(0,0,0)
                Gray  = [System.Drawing.Color]::FromArgb(168,170,168)
            }

            # Wait for a stable classification at the locked absolute position
            $check = Wait-Pixel -X $anchor.X -Y $anchor.Y -Targets $targets -Skips $skips -Tolerance 70 -StableReads 2 -SamplesPerRead 2 -Kernel 1 -SettleMs 10 -TimeoutMs 2000

            # Move once to the known relative point
            & $Clavier /sendkeys "[{Focus,0,*EPS/*}][{MouseMoveToFocus,701,692}]"
            Start-sleep -Milliseconds 40
            switch ($check.Result) {
                'Success' { $MTMSuccess = 1
                Write-Host "MTM Success!"}
                'Skip'    { $MTMSkip    = 1 }
                'Timeout' { $MTMSkip    = 1 }
            }
        }

        Start-sleep -Milliseconds 100

        # (Preserved original AppActivate logic)
        if (-not ([Microsoft.VisualBasic.Interaction]::AppActivate("Information"))) {
            & $Clavier /sendkeys "[{Focus,0,Information*}][ENTER]"
            Start-sleep -Milliseconds 400
        }
        if (-not ([Microsoft.VisualBasic.Interaction]::AppActivate("Message"))) {
            & $Clavier /sendkeys "[{Focus,0,Message*}][ENTER]"
            Start-sleep -Milliseconds 400
        }
        if (-not ([Microsoft.VisualBasic.Interaction]::AppActivate("Counseling"))) {
            & $Clavier /sendkeys "[{Focus,0,Counseling*}][ENTER][][{Focus,0,Message*}][ENTER][]"
            Start-sleep -Milliseconds 400
        }

        if ($MTMSuccess -eq 1) {
            Start-sleep -Milliseconds 300
            & $Clavier /sendkeys "[{Focus,0,MTM*}][Alt+C]"
            Start-sleep -Milliseconds 100
        }

        Start-sleep -Milliseconds 100

        #Counsel Next Check Loop
        $CheckStop = 0
        Do {
            #Check Status 1
            & $Clavier /sendkeys "[{Focus,0,*EPS/*}][{MouseMoveToFocus,189,385}]"
            Start-sleep -Milliseconds 40

            # --- ROBUST COLOR CHECK (replaces string compare for green/white) ---
            $anchor2 = Wait-CursorStable -StableMs 40 -PollMs 20 -TimeoutMs 200
            $isGreen = $false
            $isWhite = $false
            if ($anchor2) {
                $targets = @{ GoGreen = [System.Drawing.Color]::FromArgb(7,165,5) }
                $skips   = @{ White   = [System.Drawing.Color]::FromArgb(251,251,251) }

                $cls1 = Wait-Pixel -X $anchor2.X -Y $anchor2.Y -Targets $targets -Skips $skips -Tolerance 20 -StableReads 2 -SamplesPerRead 2 -Kernel 3 -SettleMs 20 -TimeoutMs 300
                if ($cls1.Result -eq 'Success') { $isGreen = $true }
                elseif ($cls1.Result -eq 'Skip') { $isWhite = $true }
            }
            # --- END ROBUST COLOR CHECK ---

            #Stop if green
            if ($isGreen) {
                $CheckStop = 1
                break
            }
            & $Clavier /sendkeys "[{Focus,0,MTM*}][Alt+C]"
            Start-sleep -Milliseconds 100
            & $Clavier /sendkeys "[{Focus,0,*EPS/*}][Alt+f][][Alt+x]"
            Start-sleep -Milliseconds 200
            if (-not ([Microsoft.VisualBasic.Interaction]::AppActivate("Information"))) {
                & $Clavier /sendkeys "[{Focus,0,Information*}][ENTER]"
                Start-sleep -Milliseconds 300
            }
            if (-not ([Microsoft.VisualBasic.Interaction]::AppActivate("Message"))) {
                & $Clavier /sendkeys "[{Focus,0,Message*}][ENTER]"
                Start-sleep -Milliseconds 300
            }
            if (-not ([Microsoft.VisualBasic.Interaction]::AppActivate("Counseling"))) {
                & $Clavier /sendkeys "[{Focus,0,Counseling*}][ENTER][][{Focus,0,Message*}][ENTER][]"
                Start-sleep -Milliseconds 300
            }
            & $Clavier /sendkeys "[{Focus,0,*EPS/*}][{MouseMoveToFocus,189,385}]"
            Start-sleep -Milliseconds 10

            # --- ROBUST COLOR CHECK (second sample mirrors your original logic) ---
            $anchor3 = Wait-CursorStable -StableMs 40 -PollMs 20 -TimeoutMs 300
            $isGreen2 = $false
            $isWhite2 = $false
            if ($anchor3) {
                $targets = @{ GoGreen = [System.Drawing.Color]::FromArgb(7,165,5) }
                $skips   = @{ White   = [System.Drawing.Color]::FromArgb(251,251,251) }

                $cls2 = Wait-Pixel -X $anchor3.X -Y $anchor3.Y -Targets $targets -Skips $skips -Tolerance 70 -StableReads 2 -SamplesPerRead 2 -Kernel 1 -SettleMs 10 -TimeoutMs 300
                if ($cls2.Result -eq 'Success') { $isGreen2 = $true }
                elseif ($cls2.Result -eq 'Skip') { $isWhite2 = $true }
            }

            if ($isGreen2) {
                $CheckStop = 1
            }
            if ($isWhite2) {
                Continue
            }

            if ($isGreen2) {
                $CheckStop = 1
            }
            # --- END ROBUST COLOR CHECK ---

        } Until (($CheckStop -eq 1))

        Start-sleep -Milliseconds 400
        if (-not ([Microsoft.VisualBasic.Interaction]::AppActivate("Information"))) {
            & $Clavier /sendkeys "[{Focus,0,Information*}][ENTER]"
            Start-sleep -Milliseconds 400
        }
        if (-not ([Microsoft.VisualBasic.Interaction]::AppActivate("Message"))) {
            & $Clavier /sendkeys "[{Focus,0,Message*}][ENTER]"
            Start-sleep -Milliseconds 400
        }
        if (-not ([Microsoft.VisualBasic.Interaction]::AppActivate("Counseling"))) {
            & $Clavier /sendkeys "[{Focus,0,Counseling*}][ENTER][][{Focus,0,Message*}][ENTER][]"
            Start-sleep -Milliseconds 400
        }

        if ($CheckStop -eq 1) {
            & $Clavier /sendkeys "[{Focus,0,*EPS/*}][Alt+C]"
            Start-sleep -Milliseconds 400
            & $Clavier /sendkeys $Auth
            Start-sleep -Milliseconds 1000

            if (-not ([Microsoft.VisualBasic.Interaction]::AppActivate("Counseling"))) {
                & $Clavier /sendkeys "[{Focus,0,Counseling*}][Alt+y]"
            }
            if (-not ([Microsoft.VisualBasic.Interaction]::AppActivate("Multiple"))) {
                Write-Host "EXIT: MULTIPLE"
                exit
            }
            Start-sleep -Milliseconds 300
            if (-not ([Microsoft.VisualBasic.Interaction]::AppActivate("Login"))) {
                Write-Host "EXIT: LOGIN"
                exit
            }
            Start-sleep -Milliseconds 500
        }
        else {
            Write-Host "EXIT"
            exit
        }
    } Until ($Done -eq 1)


}
else {
    Write-Host 'Canceled'
}
